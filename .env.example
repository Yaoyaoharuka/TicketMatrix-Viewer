# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）

# 飞书应用凭证（必填，缺失则无法读取表格）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书表格 token（必填，后端只从 .env / 环境变量读取）
FEISHU_POLL_INTERVAL=60
FEISHU_SERVERS_TOKEN=
FEISHU_SHEET_BTS=
FEISHU_SHEET_SVT=
FEISHU_SHEET_TWS=
FEISHU_SHEET_WKD=

# 也可以改用单个 JSON 变量完整配置：
# FEISHU_SHEETS_JSON={"poll_interval":60,"servers":"<服务器表 token>","sheets":{"bts":"<场次表 token>"}}

# 管理员登录（不设置 VIEWER_ADMIN_PASSWORD 则管理员入口禁用）
VIEWER_ADMIN_USER=Admin
VIEWER_ADMIN_PASSWORD=
